OPENAI_API_KEY=sk-proj-...

# ── Optional – override defaults ──────────────────────────────────────────────
# Path to the SQLite database file (default: cashflo_sample.db in project root)
# CASHFLO_DB=cashflo_sample.db

# Path to the semantic layer YAML (default: semantic_layer.yaml in project root)
# CASHFLO_YAML=semantic_layer.yaml

# Path to the query cache SQLite file (default: query_cache.db in project root)
# CASHFLO_CACHE_DB=query_cache.db

# Maximum number of LLM self-correction retries on SQL error (default: 1)
# CASHFLO_MAX_RETRIES=1

# Disable query cache entirely (set to "true" to disable)
# CASHFLO_NO_CACHE=false

# Streamlit server port (default: 8501)
# STREAMLIT_SERVER_PORT=8501
